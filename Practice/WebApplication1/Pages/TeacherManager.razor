@page "/teachers"
@using DomainCore
@using DomainCore.DTO
@using EFRepository
@using WebApplication1.Components
@using WebApplication1.Helpers
@inject ITeacherRepository TeacherRepository
@inject ISubjectRepository SubjectRepository
@namespace WebApplication1.Pages

<h3>Управление преподавателями</h3>
<div style="margin-bottom: 20px;">
    <a href="/" style="display: inline-flex; align-items: center; text-decoration: none; color: #0066cc; font-size: 0.95rem; font-weight: 500;">
        <span style="margin-right: 6px;">←</span> На главную страницу
    </a>
</div>
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error">@errorMessage</div>
}

<div style="border: 1px solid #ccc; padding: 15px; border-radius: 4px;">
    <h4>@(isEditing ? $"Редактирование преподавателя (ID: {currentTeacher.ID})" : "Добавить нового преподавателя")</h4>
    
    <div class="form-group" style="margin-bottom: 15px;">
        <label for="teacherFio">ФИО преподавателя:</label>
        <input id="teacherFio" type="text" @bind="currentTeacher.FIO" 
               placeholder="Например: Иванов Иван Иванович..." 
               style="width: 100%; padding: 6px; box-sizing: border-box; @(fioError != null ? "border: 1px solid #d32f2f;" : "")" />
        @if (fioError != null)
        {
            <div style="color: #d32f2f; font-size: 0.8rem; margin-top: 4px;">@fioError</div>
        }
        <div style="color: #666; font-size: 0.75rem; margin-top: 2px;">
            Формат: Фамилия Имя [Отчество], каждое слово с заглавной буквы
        </div>
    </div>

    <div class="form-group" style="margin-bottom: 15px;">
        <label>Закрепленные предметы:</label>
        @if (availableSubjects == null)
        {
            <p><em>Загрузка доступных предметов...</em></p>
        }
        else if (!availableSubjects.Any())
        {
            <p style="color: #666; font-style: italic;">Сначала добавьте предметы на странице управления предметами.</p>
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; max-height: 150px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; border-radius: 4px; background: #fafafa;">
                @foreach (var subject in availableSubjects)
                {
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: normal;">
                        <input type="checkbox" 
                               checked="@selectedSubjectNames.Contains(subject.NameSubjects)" 
                               @onchange="(e) => ToggleSubjectSelection(subject.NameSubjects, e.Value)" />
                        @subject.NameSubjects
                    </label>
                }
            </div>
        }
    </div>

    <button @onclick="ProcessSave">@buttonText</button>
    
    @if (isEditing)
    {
        <button class="btn-secondary" @onclick="CancelEdit">Отмена</button>
    }
</div>

<hr />

<h4>Список преподавателей</h4>
@if (teachers == null)
{
    <p><em>Загрузка данных...</em></p>
}
else if (!teachers.Any())
{
    <p>Преподаватели пока не добавлены.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>ФИО преподавателя</th>
                <th>Предметы</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in teachers)
            {
                <tr @key="t.ID">
                    <td>@t.ID</td>
                    <td>@t.FIO</td>
                    <td>
                        @if (t.SubjectsName != null && t.SubjectsName.Any())
                        {
                            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                @foreach (var sub in t.SubjectsName)
                                {
                                    <span style="background: #eef2f7; border: 1px solid #d0d7de; padding: 2px 8px; border-radius: 12px; font-size: 0.85rem;">@sub</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span style="color: #999; font-style: italic;">Нет предметов</span>
                        }
                    </td>
                    <td class="actions">
                        <button @onclick="() => StartEdit(t)">Редактировать</button>
                        <button class="btn-danger" @onclick="() => RequestDelete(t)">Удалить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<ConfirmDialog IsOpen="showDeleteConfirmation"
               Title="Удаление преподавателя"
               Message="@($"Вы действительно хотите удалить преподавателя \"{teacherToDelete?.FIO}\"?. Удаление преподаватели каскадно удалит связанные с ним пары")"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

<ConfirmDialog IsOpen="showEditConfirmation"
               Title="Сохранение изменений"
               Message="Вы действительно хотите сохранить изменения для этого преподавателя?"
               OnConfirm="ConfirmSaveEdit"
               OnCancel="CancelEditDialog" />

<ErrorDialog IsOpen="showErrorDialog"
             Title="Произошла ошибка"
             Message="@dialogErrorMessage"
             OnClose="CloseErrorDialog" />

@code {
    private List<TeacherDto> teachers = new();
    private List<Subject> availableSubjects = new();
    private List<string> selectedSubjectNames = new();
    
    private TeacherDto currentTeacher = new() { SubjectsName = new List<string>() }; 
    private string errorMessage = string.Empty;
    private bool isEditing = false;
    private string buttonText => isEditing ? "Сохранить изменения" : "Добавить";
    
    private bool showDeleteConfirmation = false;
    private TeacherDto? teacherToDelete;
    private bool showEditConfirmation = false;

    private bool showErrorDialog = false;
    private string dialogErrorMessage = string.Empty;

    private string? fioError;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubjects();
        await LoadTeachers();
    }

    private async Task LoadSubjects()
    {
        var result = await SubjectRepository.GetAllSubjectsAsync();
        availableSubjects = result?.ToList() ?? new List<Subject>();
    }

    private async Task LoadTeachers()
    {
        errorMessage = string.Empty;
        var result = await TeacherRepository.GetAllTeachersAsync();
        teachers = result ?? new List<TeacherDto>();
    }

    private void ToggleSubjectSelection(string subjectName, object? checkedValue)
    {
        bool isChecked = checkedValue is bool b && b;
        if (isChecked)
        {
            if (!selectedSubjectNames.Contains(subjectName))
            {
                selectedSubjectNames.Add(subjectName);
            }
        }
        else
        {
            selectedSubjectNames.Remove(subjectName);
        }
    }

    private async Task ProcessSave()
    {
        fioError = null;

        var (isValid, error) = Validators.ValidateTeacherFio(currentTeacher.FIO);
        if (!isValid)
        {
            fioError = error;
            ShowError("Пожалуйста, исправьте ошибки в форме.");
            return;
        }

        currentTeacher.SubjectsName = selectedSubjectNames.ToList();

        if (isEditing)
        {
            showEditConfirmation = true;
        }
        else
        {
            await ExecuteCreate();
        }
    }

    private async Task ExecuteCreate()
    {
        var newId = await TeacherRepository.CreateAsync(currentTeacher);
        if (newId == null)
        {
            ShowError($"Преподаватель '{currentTeacher.FIO}' уже существует или один из выбранных предметов стал недоступен.");
            return;
        }
        CancelEdit();
        await LoadTeachers();
    }

    private async Task ConfirmSaveEdit()
    {
        showEditConfirmation = false;

        var result = await TeacherRepository.UpdateAsync(currentTeacher);
        if (result == null)
        {
            ShowError("Не удалось обновить данные преподавателя. Проверьте актуальность предметов или базы данных.");
            return;
        }

        CancelEdit();
        await LoadTeachers();
    }

    private void CancelEditDialog()
    {
        showEditConfirmation = false;
    }

    private void StartEdit(TeacherDto teacherDto)
    {
        currentTeacher = new TeacherDto 
        { 
            ID = teacherDto.ID, 
            FIO = teacherDto.FIO
        };
        selectedSubjectNames = teacherDto.SubjectsName != null 
            ? teacherDto.SubjectsName.ToList() 
            : new List<string>();
            
        isEditing = true;
        errorMessage = string.Empty;
        fioError = null;
    }

    private void CancelEdit()
    {
        currentTeacher = new TeacherDto { SubjectsName = new List<string>() };
        selectedSubjectNames.Clear();
        isEditing = false;
        errorMessage = string.Empty;
        showEditConfirmation = false;
        fioError = null;
    }

    private void RequestDelete(TeacherDto teacherDto)
    {
        teacherToDelete = teacherDto;
        showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        teacherToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (teacherToDelete == null) return;

        var id = teacherToDelete.ID;
        showDeleteConfirmation = false; 

        var result = await TeacherRepository.DeleteAsync(id);
        if (result == null)
        {
            ShowError("Не удалось удалить преподавателя. Возможно, он связан со сформированными уроками.");
            teacherToDelete = null;
            return;
        }
        
        if (isEditing && currentTeacher.ID == id)
        {
            CancelEdit();
        }

        teacherToDelete = null;
        await LoadTeachers();
    }

    private void ShowError(string message)
    {
        dialogErrorMessage = message;
        errorMessage = message;
        showErrorDialog = true;
    }

    private void CloseErrorDialog()
    {
        showErrorDialog = false;
        dialogErrorMessage = string.Empty;
    }
}
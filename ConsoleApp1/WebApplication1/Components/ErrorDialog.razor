@if (IsOpen)
{
    <div class="modal-backdrop" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1060; background: rgba(0,0,0,0.4);"></div>
    <div class="modal" tabindex="-1" style="display: block; z-index: 1070; position: fixed; top: 20%; left: 50%; transform: translate(-50%, 0); max-width: 450px; width: 100%;" role="dialog">
        <div class="modal-content" style="background: white; border: 1px solid #dc3545; border-radius: 6px; box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3); padding: 20px;">
            <div class="modal-header" style="padding-bottom: 10px; border-bottom: 1px solid #e5e5e5; display: flex; justify-content: space-between; align-items: center;">
                <h5 class="modal-title" style="margin: 0; font-size: 1.25rem; color: #dc3545; font-weight: bold;">@Title</h5>
                <button type="button" class="close" @onclick="OnClose" style="background: transparent; border: 0; font-size: 1.5rem; cursor: pointer; color: #6c757d;">&times;</button>
            </div>
            <div class="modal-body" style="padding: 20px 0;">
                <p style="margin: 0; font-size: 1rem;">@Message</p>
            </div>
            <div class="modal-footer" style="padding-top: 10px; border-top: 1px solid #e5e5e5; text-align: right; display: flex; justify-content: flex-end;">
                <button type="button" class="btn btn-danger" @onclick="OnClose" style="background-color: #dc3545; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer;">ОК</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string Title { get; set; } = "Ошибка";
    [Parameter] public string Message { get; set; } = "Что-то пошло не так.";
    [Parameter] public EventCallback OnClose { get; set; }
}
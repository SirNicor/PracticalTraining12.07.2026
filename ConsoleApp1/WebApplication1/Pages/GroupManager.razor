@page "/groups"
@using DomainCore
@using DomainCore.DTO
@using EFRepository
@using WebApplication1.Components
@inject IGroupRepository GroupRepository
@inject ISubjectRepository SubjectRepository
@namespace WebApplication1.Pages

<h3>Управление группами</h3>
<div style="margin-bottom: 20px;">
    <a href="/" style="display: inline-flex; align-items: center; text-decoration: none; color: #0066cc; font-size: 0.95rem; font-weight: 500;">
        <span style="margin-right: 6px;">←</span> На главную страницу
    </a>
</div>
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error">@errorMessage</div>
}

<div style="border: 1px solid #ccc; padding: 15px; border-radius: 4px;">
    <h4>@(isEditing ? $"Редактирование группы (ID: {currentGroup.ID})" : "Добавить новую группу")</h4>
    
    <div class="form-group" style="margin-bottom: 15px;">
        <label for="groupName">Название группы:</label>
        <input id="groupName" type="text" @bind="currentGroup.NameGroup" placeholder="Введите название группы..." style="width: 100%; padding: 6px; box-sizing: border-box;" />
    </div>

    <div class="form-group" style="margin-bottom: 15px;">
        <label>Изучаемые предметы:</label>
        @if (availableSubjects == null)
        {
            <p><em>Загрузка доступных предметов...</em></p>
        }
        else if (!availableSubjects.Any())
        {
            <p style="color: #666; font-style: italic;">Сначала добавьте предметы на странице управления предметами.</p>
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; max-height: 150px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; border-radius: 4px; background: #fafafa;">
                @foreach (var subject in availableSubjects)
                {
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: normal;">
                        <input type="checkbox" 
                               checked="@selectedSubjectNames.Contains(subject.NameSubjects)" 
                               @onchange="(e) => ToggleSubjectSelection(subject.NameSubjects, e.Value)" />
                        @subject.NameSubjects
                    </label>
                }
            </div>
        }
    </div>

    <button @onclick="ProcessSave">@buttonText</button>
    
    @if (isEditing)
    {
        <button class="btn-secondary" @onclick="CancelEdit">Отмена</button>
    }
</div>

<hr />

<h4>Список групп</h4>
@if (groups == null)
{
    <p><em>Загрузка данных...</em></p>
}
else if (!groups.Any())
{
    <p>Группы пока не добавлены.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Название группы</th>
                <th>Предметы</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var g in groups)
            {
                <tr @key="g.ID">
                    <td>@g.ID</td>
                    <td>@g.NameGroup</td>
                    <td>
                        @if (g.SubjectsName != null && g.SubjectsName.Any())
                        {
                            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                                @foreach (var sub in g.SubjectsName)
                                {
                                    <span style="background: #eef2f7; border: 1px solid #d0d7de; padding: 2px 8px; border-radius: 12px; font-size: 0.85rem;">@sub</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span style="color: #999; font-style: italic;">Нет предметов</span>
                        }
                    </td>
                    <td class="actions">
                        <button @onclick="() => StartEdit(g)">Редактировать</button>
                        <button class="btn-danger" @onclick="() => RequestDelete(g)">Удалить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<ConfirmDialog IsOpen="showDeleteConfirmation"
               Title="Удаление группы"
               Message="@($"Вы действительно хотите удалить группу \"{groupToDelete?.NameGroup}\"?")"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

<ConfirmDialog IsOpen="showEditConfirmation"
               Title="Сохранение изменений"
               Message="Вы действительно хотите сохранить изменения для этой группы?"
               OnConfirm="ConfirmSaveEdit"
               OnCancel="CancelEditDialog" />

<ErrorDialog IsOpen="showErrorDialog"
             Title="Произошла ошибка"
             Message="@dialogErrorMessage"
             OnClose="CloseErrorDialog" />

@code {
    private List<GroupDto> groups = new();
    private List<Subject> availableSubjects = new();
    private List<string> selectedSubjectNames = new();
    
    private GroupDto currentGroup = new() { SubjectsName = new List<string>() }; 
    private string errorMessage = string.Empty;
    private bool isEditing = false;
    private string buttonText => isEditing ? "Сохранить изменения" : "Добавить";
    
    private bool showDeleteConfirmation = false;
    private GroupDto? groupToDelete;
    private bool showEditConfirmation = false;

    private bool showErrorDialog = false;
    private string dialogErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubjects();
        await LoadGroups();
    }

    private async Task LoadSubjects()
    {
        var result = await SubjectRepository.GetAllSubjectsAsync();
        availableSubjects = result?.ToList() ?? new List<Subject>();
    }

    private async Task LoadGroups()
    {
        errorMessage = string.Empty;
        var result = await GroupRepository.GetAllGroupsAsync();
        groups = result ?? new List<GroupDto>();
    }

    private void ToggleSubjectSelection(string subjectName, object? checkedValue)
    {
        bool isChecked = checkedValue is bool b && b;
        if (isChecked)
        {
            if (!selectedSubjectNames.Contains(subjectName))
            {
                selectedSubjectNames.Add(subjectName);
            }
        }
        else
        {
            selectedSubjectNames.Remove(subjectName);
        }
    }

    private async Task ProcessSave()
    {
        if (string.IsNullOrWhiteSpace(currentGroup.NameGroup))
        {
            ShowError("Название группы обязательно для заполнения.");
            return;
        }

        currentGroup.SubjectsName = selectedSubjectNames.ToList();

        if (isEditing)
        {
            showEditConfirmation = true;
        }
        else
        {
            await ExecuteCreate();
        }
    }

    private async Task ExecuteCreate()
    {
        var newId = await GroupRepository.CreateAsync(currentGroup);
        if (newId == null)
        {
            ShowError($"Группа '{currentGroup.NameGroup}' уже существует или один из выбранных предметов стал недоступен.");
            return;
        }
        CancelEdit();
        await LoadGroups();
    }

    private async Task ConfirmSaveEdit()
    {
        showEditConfirmation = false;

        var result = await GroupRepository.UpdateAsync(currentGroup);
        if (result == null)
        {
            ShowError("Не удалось обновить данные группы. Проверьте актуальность предметов или базы данных.");
            return;
        }

        CancelEdit();
        await LoadGroups();
    }

    private void CancelEditDialog()
    {
        showEditConfirmation = false;
    }

    private void StartEdit(GroupDto groupDto)
    {
        currentGroup = new GroupDto 
        { 
            ID = groupDto.ID, 
            NameGroup = groupDto.NameGroup
        };
        selectedSubjectNames = groupDto.SubjectsName != null 
            ? groupDto.SubjectsName.ToList() 
            : new List<string>();
            
        isEditing = true;
        errorMessage = string.Empty;
    }

    private void CancelEdit()
    {
        currentGroup = new GroupDto { SubjectsName = new List<string>() };
        selectedSubjectNames.Clear();
        isEditing = false;
        errorMessage = string.Empty;
        showEditConfirmation = false;
    }

    private void RequestDelete(GroupDto groupDto)
    {
        groupToDelete = groupDto;
        showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        groupToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (groupToDelete == null) return;

        var id = groupToDelete.ID;
        showDeleteConfirmation = false; 

        var result = await GroupRepository.DeleteAsync(id);
        if (result == null)
        {
            ShowError("Не удалось удалить группу. Возможно, она связана со сформированными уроками.");
            groupToDelete = null;
            return;
        }
        
        if (isEditing && currentGroup.ID == id)
        {
            CancelEdit();
        }

        groupToDelete = null;
        await LoadGroups();
    }

    private void ShowError(string message)
    {
        dialogErrorMessage = message;
        errorMessage = message;
        showErrorDialog = true;
    }

    private void CloseErrorDialog()
    {
        showErrorDialog = false;
        dialogErrorMessage = string.Empty;
    }
}
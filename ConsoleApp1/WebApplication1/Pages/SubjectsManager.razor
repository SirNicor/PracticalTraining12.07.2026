@page "/subjects"
@using DomainCore
@using EFRepository
@using WebApplication1.Components
@inject ISubjectRepository Repository
@namespace WebApplication1.Pages

<h3>Управление предметами</h3>
<div style="margin-bottom: 20px;">
    <a href="/" style="display: inline-flex; align-items: center; text-decoration: none; color: #0066cc; font-size: 0.95rem; font-weight: 500;">
        <span style="margin-right: 6px;">←</span> На главную страницу
    </a>
</div>
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error">@errorMessage</div>
}

<div style="border: 1px solid #ccc; padding: 15px; border-radius: 4px;">
    <h4>@(isEditing ? $"Редактирование предмета (ID: {currentSubject.ID})" : "Добавить новый предмет")</h4>
    
    <div class="form-group">
        <label for="subjectName">Название предмета:</label>
        <input id="subjectName" type="text" @bind="currentSubject.NameSubjects" placeholder="Введите название..." />
    </div>

    <button @onclick="ProcessSave">@buttonText</button>
    
    @if (isEditing)
    {
        <button class="btn-secondary" @onclick="CancelEdit">Отмена</button>
    }
</div>

<hr />

<h4>Список предметов</h4>
@if (subjects == null)
{
    <p><em>Загрузка данных...</em></p>
}
else if (!subjects.Any())
{
    <p>Предметы пока не добавлены.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in subjects)
            {
                <tr @key="s.ID">
                    <td>@s.ID</td>
                    <td>@s.NameSubjects</td>
                    <td class="actions">
                        <button @onclick="() => StartEdit(s)">Редактировать</button>
                        <button class="btn-danger" @onclick="() => RequestDelete(s)">Удалить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<ConfirmDialog IsOpen="showDeleteConfirmation"
               Title="Удаление предмета"
               Message="@($"Вы действительно хотите удалить предмет \"{subjectToDelete?.NameSubjects}\"?")"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

<ConfirmDialog IsOpen="showEditConfirmation"
               Title="Сохранение изменений"
               Message="Вы действительно хотите сохранить изменения в этом предмете?"
               OnConfirm="ConfirmSaveEdit"
               OnCancel="CancelEditDialog" />

<ErrorDialog IsOpen="showErrorDialog"
             Title="Произошла ошибка"
             Message="@dialogErrorMessage"
             OnClose="CloseErrorDialog" />

@code {
    private List<Subject> subjects = new();
    private Subject currentSubject = new(); 
    private string errorMessage = string.Empty;
    private bool isEditing = false;
    private string buttonText => isEditing ? "Сохранить изменения" : "Добавить";
    
    private bool showDeleteConfirmation = false;
    private Subject? subjectToDelete;
    private bool showEditConfirmation = false;

    private bool showErrorDialog = false;
    private string dialogErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubjects();
    }

    private async Task LoadSubjects()
    {
        errorMessage = string.Empty;
        var result = await Repository.GetAllSubjectsAsync();
        subjects = result?.ToList() ?? new List<Subject>();
    }

    private async Task ProcessSave()
    {
        if (string.IsNullOrWhiteSpace(currentSubject.NameSubjects))
        {
            ShowError("Название предмета обязательно для заполнения.");
            return;
        }

        if (isEditing)
        {
            showEditConfirmation = true;
        }
        else
        {
            await ExecuteCreate();
        }
    }

    private async Task ExecuteCreate()
    {
        var newId = await Repository.CreateAsync(currentSubject);
        if (newId == null)
        {
            ShowError($"Предмет '{currentSubject.NameSubjects}' уже существует или произошла ошибка при добавлении.");
            return;
        }
        CancelEdit();
        await LoadSubjects();
    }

    private async Task ConfirmSaveEdit()
    {
        showEditConfirmation = false;

        var result = await Repository.UpdateAsync(currentSubject);
        if (result == null)
        {
            ShowError("Не удалось обновить предмет. Возможно, он был удален другим пользователем.");
            return;
        }

        CancelEdit();
        await LoadSubjects();
    }

    private void CancelEditDialog()
    {
        showEditConfirmation = false;
    }

    private void StartEdit(Subject subject)
    {
        currentSubject = new Subject 
        { 
            ID = subject.ID, 
            NameSubjects = subject.NameSubjects 
        };
        isEditing = true;
        errorMessage = string.Empty;
    }

    private void CancelEdit()
    {
        currentSubject = new Subject();
        isEditing = false;
        errorMessage = string.Empty;
        showEditConfirmation = false;
    }

    private void RequestDelete(Subject subject)
    {
        subjectToDelete = subject;
        showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        subjectToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (subjectToDelete == null) return;

        var id = subjectToDelete.ID;
        showDeleteConfirmation = false; 

        var result = await Repository.DeleteAsync(id);
        if (result == null)
        {
            ShowError("Не удалось удалить предмет. Возможно, он уже был удален из базы данных.");
            subjectToDelete = null;
            return;
        }
        
        if (isEditing && currentSubject.ID == id)
        {
            CancelEdit();
        }

        subjectToDelete = null;
        await LoadSubjects();
    }

    private void ShowError(string message)
    {
        dialogErrorMessage = message;
        errorMessage = message;
        showErrorDialog = true;
    }

    private void CloseErrorDialog()
    {
        showErrorDialog = false;
        dialogErrorMessage = string.Empty;
    }
}